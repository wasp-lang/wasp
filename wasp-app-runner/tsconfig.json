{
  "include": ["src"],
  "compilerOptions": {
    "allowImportingTsExtensions": true,
    "allowJs": true,
    "erasableSyntaxOnly": true,
    "isolatedModules": true,
    "lib": ["es2025"],
    "noEmit": true,
    "noUncheckedIndexedAccess": true,
    "resolveJsonModule": true,
    "rootDir": "src",
    "skipLibCheck": true,
    "strict": true,
    "target": "es2025",
    "types": ["node/"],
    "verbatimModuleSyntax": true,
    "module": "node20"
  }
}
