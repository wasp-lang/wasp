{
  "name": "@waspello/stripe-payments",
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    ".wasp/out/sdk/wasp"
  ],
  "files": [
    "dist"
  ],
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./*": {
      "types": "./dist/*.d.ts",
      "default": "./dist/*.js"
    }
  },
  "scripts": {
    "build": "wasp module build && tsc -p tsconfig.build.json",
    "dev": "wasp module build --watch"
  },
  "dependencies": {
    "stripe": "^17.7.0"
  },
  "peerDependencies": {
    "@tanstack/react-query": "~4.42.0",
    "axios": "^1.4.0",
    "express": "~5.1.0",
    "react": "^19.0.0",
    "react-router": "^7.0.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@prisma/client": "5.19.1",
    "@types/express": "^5.0.0",
    "@types/react": "^19.2.7",
    "prisma": "5.19.1",
    "typescript": "5.8.2",
    "wasp-config": "file:.wasp/packages/wasp-config"
  }
}
