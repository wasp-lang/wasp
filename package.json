{
  "name": "wasp-repo",
  "type": "module",
  "private": true,
  "workspaces": [
    "examples/*",
    "examples/tutorials/*",
    "mage",
    "scripts/make-npm-packages",
    "wasp-app-runner",
    "waspc/data/Generator/libs/*",
    "waspc/data/packages/*",
    "waspc/data/packages/studio/client",
    "waspc/starters-e2e-tests",
    "waspc/tools",
    "web",
    "web/tutorial-actions-executor"
  ],
  "scripts": {
    "check:prettier": "prettier --ignore-unknown --check --config prettier.config.mjs .",
    "format:prettier": "prettier --ignore-unknown --write --config prettier.config.mjs ."
  },
  "devDependencies": {
    "prettier": "3.5.3",
    "prettier-plugin-organize-imports": "4.1.0",
    "prettier-plugin-pkg": "0.19.1",
    "prettier-plugin-sh": "0.17.4",
    "prettier-plugin-tailwindcss": "0.7.2",
    "typescript": "~5.8.3"
  }
}
