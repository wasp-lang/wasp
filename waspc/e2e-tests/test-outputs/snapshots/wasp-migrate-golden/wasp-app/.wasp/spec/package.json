{
  "//": [
    "We pin `vitest` version because type tests are an experimental feature,",
    "and changes to API are not breaking changes."
  ],
  "author": "wasp",
  "bin": {
    "__internal_wasp_spec__": "./dist/src/run.js"
  },
  "dependencies": {
    "type-fest": "^5.6.0",
    "typescript": "^5.8.3"
  },
  "description": "Wasp TS SDK",
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/node": "^22.17.0",
    "@vitest/coverage-v8": "^3.1.2",
    "eslint": "^9.9.0",
    "globals": "^15.9.0",
    "nodemon": "^3.1.4",
    "typescript-eslint": "^8.1.0",
    "vitest": "3.1.2"
  },
  "exports": {
    ".": {
      "default": "./dist/src/index.js",
      "types": "./dist/src/index.d.ts"
    }
  },
  "license": "MIT",
  "name": "@wasp.sh/spec",
  "scripts": {
    "build": "tsc",
    "coverage": "vitest run --coverage",
    "dev": "nodemon ./src/index.ts",
    "test": "vitest run --reporter=verbose",
    "test:integration": "vitest run --reporter=verbose --project integration",
    "test:type": "vitest run --reporter=verbose --project type",
    "test:unit": "vitest run --reporter=verbose --project unit",
    "test:watch": "vitest --reporter=verbose"
  },
  "type": "module",
  "version": "0.24.0"
}
