{
  "include": ["src/**/*", "tests/**/*"],
  "extends": ["@tsconfig/node22", "@tsconfig/node-ts"],
  "compilerOptions": {
    "target": "esnext",
    "module": "esnext",
    "moduleResolution": "bundler",

    "verbatimModuleSyntax": true,
    "erasableSyntaxOnly": true,
    "types": ["node"]
  }
}
