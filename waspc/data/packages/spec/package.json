{
  "name": "@wasp.sh/spec",
  "version": "0.24.0",
  "type": "module",
  "description": "Wasp TS SDK",
  "author": "wasp",
  "license": "MIT",
  "bin": {
    "__internal_wasp_spec__": "./dist/src/run.js"
  },
  "exports": {
    ".": {
      "types": "./dist/src/index.d.ts",
      "default": "./dist/src/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "coverage": "vitest run --coverage",
    "dev": "nodemon ./src/index.ts",
    "test": "vitest run --reporter=verbose",
    "test:integration": "vitest run --reporter=verbose --project integration",
    "test:type": "vitest run --reporter=verbose --project type",
    "test:unit": "vitest run --reporter=verbose --project unit",
    "test:watch": "vitest --reporter=verbose"
  },
  "dependencies": {
    "jiti": "^2.7.0",
    "ts-morph": "^28.0.0",
    "type-fest": "^5.6.0",
    "typescript": "^5.8.3"
  },
  "devDependencies": {
    "@eslint/js": "^9.9.0",
    "@types/node": "^22.17.0",
    "@vitest/coverage-v8": "^4.0.16",
    "eslint": "^9.9.0",
    "globals": "^15.9.0",
    "nodemon": "^3.1.4",
    "typescript-eslint": "^8.1.0",
    "vitest": "^4.0.16"
  },
  "//": [
    "Keep `vitest` and `@vitest/coverage-v8` compatible with the Vitest version at `src/Wasp/Generator/SdkGenerator.hs`.",
    "Mismatched Vitest majors make npm install separate copies; production builds remove `@wasp.sh/spec`, so app test files can no longer resolve `vitest` during server typechecking."
  ]
}
