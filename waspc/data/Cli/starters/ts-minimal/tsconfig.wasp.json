{
  "compilerOptions": {
    "skipLibCheck": true,
    "target": "ES2022",
    "isolatedModules": true,
    "moduleDetection": "force",
    "strict": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "jsx": "preserve",
    "noEmit": true,
    "baseUrl": ".",
    "lib": ["ES2023", "DOM", "DOM.Iterable"],
    "paths": {
      "@src/*": ["src/*"]
    },
    "types": ["vite/client", "react"]
  },
  "include": ["main.wasp.ts"]
}
