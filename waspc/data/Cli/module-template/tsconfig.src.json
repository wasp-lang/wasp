{
  "compilerOptions": {
    "module": "esnext",
    "target": "esnext",
    "moduleResolution": "bundler",
    "jsx": "preserve",
    "strict": true,
    "esModuleInterop": true,
    "isolatedModules": true,
    "moduleDetection": "force",
    "lib": ["dom", "dom.iterable", "esnext"],
    "skipLibCheck": true,
    "allowJs": true,
    "types": ["react", "node"],
    "noEmit": true
  },
  "include": ["src", ".wasp/wasp/ambient.d.ts"],
  "exclude": ["**/*.wasp.ts"]
}
